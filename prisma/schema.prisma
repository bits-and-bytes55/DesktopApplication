datasource db {
  provider = "sqlite"
  url      = "file:./mudpro.db"
}

generator client {
  provider = "prisma-client-js"
}

model Engineer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  cell      String?
  office    String?
  email     String?
  photoUrl  String?
  createdAt DateTime @default(now())

  // 🔁 REQUIRED reverse relations
  reportsAsEngineer1 Report[] @relation("Engineer1")
  reportsAsEngineer2 Report[] @relation("Engineer2")
}

model Report {
  id       Int    @id @default(autoincrement())
  reportNo Int
  wellName String

  engineerId  Int?
  engineer2Id Int?

  engineer  Engineer? @relation("Engineer1", fields: [engineerId], references: [id])
  engineer2 Engineer? @relation("Engineer2", fields: [engineer2Id], references: [id])

  createdAt DateTime @default(now())
}
